rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function existing() { return resource.data; }
    function incoming() { return request.resource.data; }

    function isValidReport(data) {
      return data.keys().hasAll(['title', 'description', 'createdBy', 'status', 'createdAt'])
        && data.title is string
        && data.description is string
        && data.createdBy is string
        && data.createdBy == request.auth.uid
        && data.status is string
        && data.status == 'PENDING';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /reports/{reportId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && (resource.data.createdBy == request.auth.uid || request.auth.token.email == 'barshadhn2@gmail.com');
    }
  }
}
